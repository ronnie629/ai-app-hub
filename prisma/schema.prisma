generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  passwordHash         String
  phone                String    @default("")
  role                 String    @default("USER")
  points               Int       @default(0)
  tokenVersion         Int       @default(0)
  bio                  String?   @db.Text
  avatar               String?   @db.Text
  isDeveloper          Boolean   @default(false)
  profession           String?
  interests            String?   @db.Text
  workYears            Int?
  appDomains           String?   @db.Text
  lastLoginAt          DateTime?
  lastPurchaseAt       DateTime?
  lastLevelCheckAt     DateTime?
  devLevelSnapshot     Int       @default(1)
  devLevelSnapshotMonth String?
  resetToken           String?   @unique
  resetTokenExp        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  apps         App[]
  purchases    Purchase[]
  transactions PointsTransaction[]
  reviews      Review[]

  @@map("users")
}

model App {
  id                 String         @id @default(cuid())
  title              String
  description        String         @db.Text
  category           String         @default("其他")
  appType            String         @default("WEB")
  coverImage         String?        @db.Text
  screenshots        String         @default("[]") @db.VarChar(5000)
  price              Int            @default(0)
  pricePerUse        Int            @default(-1)
  usageInstructions  String         @default("") @db.VarChar(5000)
  accessUrl          String         @default("") @db.VarChar(2048)
  tags               String         @default("[]") @db.VarChar(2000)
  developerId        String
  status             String         @default("PENDING")
  downloadCount      Int            @default(0)
  rating             Float          @default(0)
  reviewCount        Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  developer          User           @relation(fields: [developerId], references: [id])
  purchases          Purchase[]
  reviews            Review[]

  @@index([status, createdAt])
  @@index([status, downloadCount])
  @@index([status, rating])
  @@index([developerId, status])
  @@index([category, status])
  @@index([appType, status])
  @@map("apps")
}

model Purchase {
  id               String   @id @default(cuid())
  userId           String
  appId            String
  pointsCost       Int
  purchaseType     String   @default("BUYOUT")
  remainingUses    Int      @default(0)
  developerEarning Int      @default(0)
  platformEarning  Int      @default(0)
  platformFeeRate  Float    @default(0.1)
  status           String   @default("COMPLETED")
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id])
  app              App      @relation(fields: [appId], references: [id])

  @@index([userId, createdAt])
  @@index([appId, createdAt])
  @@index([status, createdAt])
  @@map("purchases")
}

model PointsTransaction {
  id           String   @id @default(cuid())
  userId       String
  type         String
  amount       Int
  balanceAfter Int
  description  String   @default("") @db.VarChar(5000)
  relatedId    String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@map("points_transactions")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  appId     String
  rating    Int
  comment   String   @default("") @db.VarChar(5000)
  tags      String   @default("[]") @db.VarChar(2000)
  reply     String?  @db.Text
  repliedAt DateTime?
  createdAt DateTime @default(now())

  app       App      @relation(fields: [appId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, appId])
  @@index([rating])
  @@map("reviews")
}

model PlatformConfig {
  id                String   @id @default("default")
  platformFeeRate   Float    @default(0.1)
  minRechargePoints Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("platform_config")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  appId     String
  createdAt DateTime @default(now())

  @@unique([userId, appId])
  @@index([userId])
  @@map("favorites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String   @default("") @db.VarChar(5000)
  link      String?  @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model AccessToken {
  id        String    @id @default(cuid())
  userId    String
  appId     String
  token     String    @unique
  status    String    @default("ACTIVE")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, appId])
  @@index([token])
  @@map("access_tokens")
}

model UserLevel {
  id             String   @id @default(cuid())
  userType       String
  level          Int
  name           String
  minConsumption Int      @default(0)
  minApps        Int      @default(0)
  minEarnings    Int      @default(0)
  devShareRate   Float    @default(0.9)
  color          String   @default("#6366f1")
  icon           String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_levels")
}
