generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  phone        String    @default("")
  role         String    @default("USER")
  points       Int       @default(0)
  bio          String?
  avatar       String?
  isDeveloper  Boolean   @default(false)
  profession   String?
  interests    String?
  workYears    Int?
  appDomains   String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  apps         App[]
  purchases    Purchase[]
  transactions PointsTransaction[]
  reviews      Review[]

  @@map("users")
}

model App {
  id                String         @id @default(cuid())
  title             String
  description       String
  category          String         @default("其他")
  appType           String         @default("WEB")
  coverImage        String?
  screenshots       String         @default("[]")
  price             Int            @default(0)
  pricePerUse       Int            @default(-1) // -1=未开启按次, 0=按次免费, >0=按次价格
  usageInstructions String         @default("")
  accessUrl         String         @default("")
  tags              String         @default("[]")
  developerId       String
  status            String         @default("PENDING")
  downloadCount     Int            @default(0)
  rating            Float          @default(0)
  reviewCount       Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  developer         User           @relation(fields: [developerId], references: [id])
  purchases         Purchase[]
  reviews           Review[]

  @@map("apps")
}

model Purchase {
  id               String   @id @default(cuid())
  userId           String
  appId            String
  pointsCost       Int
  purchaseType     String   @default("BUYOUT") // BUYOUT | PER_USE
  remainingUses    Int      @default(0) // 买断为0，按次购买为剩余次数
  developerEarning Int      @default(0)
  platformEarning  Int      @default(0)
  platformFeeRate  Float    @default(0.1) // 购买时的平台抽佣比例快照
  status           String   @default("COMPLETED")
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id])
  app              App      @relation(fields: [appId], references: [id])

  @@map("purchases")
}

model PointsTransaction {
  id           String   @id @default(cuid())
  userId       String
  type         String
  amount       Int
  balanceAfter Int
  description  String   @default("")
  relatedId    String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@map("points_transactions")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  appId     String
  rating    Int
  comment   String   @default("")
  tags      String   @default("[]")
  reply     String?
  repliedAt DateTime?
  createdAt DateTime @default(now())

  app       App      @relation(fields: [appId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, appId])
  @@index([rating])
  @@map("reviews")
}

model PlatformConfig {
  id                String  @id @default("default")
  platformFeeRate   Float   @default(0.1)
  minRechargePoints Int     @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("platform_config")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  appId     String
  createdAt DateTime @default(now())

  @@unique([userId, appId])
  @@index([userId])
  @@map("favorites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String   @default("")
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model AccessToken {
  id        String    @id @default(cuid())
  userId    String
  appId     String
  token     String    @unique
  status    String    @default("ACTIVE") // ACTIVE | USED | EXPIRED
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, appId])
  @@index([token])
  @@map("access_tokens")
}

model UserLevel {
  id             String   @id @default(cuid())
  userType       String   // "USER" | "DEVELOPER"
  level          Int      // 1=初级, 2=中级, 3=高级
  name           String   // 等级名称
  minConsumption Int      @default(0) // 用户：最低消费积分
  minApps        Int      @default(0) // 开发者：最低发布应用数
  minEarnings    Int      @default(0) // 开发者：最低赚取积分
  devShareRate   Float    @default(0.9) // 开发者分润比例（如0.7=开发者得70%）
  color          String   @default("#6366f1") // 等级颜色
  icon           String   @default("") // 等级图标
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_levels")
}
