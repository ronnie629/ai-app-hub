generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  phone        String    @default("")
  role         String    @default("USER")
  points       Int       @default(0)
  bio          String?
  avatar       String?
  isDeveloper  Boolean   @default(false)
  profession   String?
  interests    String?
  workYears    Int?
  appDomains   String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  apps         App[]
  purchases    Purchase[]
  transactions PointsTransaction[]

  @@map("users")
}

model App {
  id                String         @id @default(cuid())
  title             String
  description       String
  category          String         @default("其他")
  appType           String         @default("WEB")
  coverImage        String?
  screenshots       String         @default("[]")
  price             Int            @default(0)
  usageInstructions String         @default("")
  accessUrl         String         @default("")
  tags              String         @default("[]")
  developerId       String
  status            String         @default("PENDING")
  downloadCount     Int            @default(0)
  rating            Float          @default(0)
  reviewCount       Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  developer         User           @relation(fields: [developerId], references: [id])
  purchases         Purchase[]
  reviews           Review[]

  @@map("apps")
}

model Purchase {
  id               String   @id @default(cuid())
  userId           String
  appId            String
  pointsCost       Int
  developerEarning Int      @default(0)
  platformEarning  Int      @default(0)
  status           String   @default("COMPLETED")
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id])
  app              App      @relation(fields: [appId], references: [id])

  @@map("purchases")
}

model PointsTransaction {
  id           String   @id @default(cuid())
  userId       String
  type         String
  amount       Int
  balanceAfter Int
  description  String   @default("")
  relatedId    String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@map("points_transactions")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  appId     String
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now())

  app       App      @relation(fields: [appId], references: [id])

  @@unique([userId, appId])
  @@map("reviews")
}

model PlatformConfig {
  id                String  @id @default("default")
  platformFeeRate   Float   @default(0.1)
  minRechargePoints Int     @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("platform_config")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  appId     String
  createdAt DateTime @default(now())

  @@unique([userId, appId])
  @@index([userId])
  @@map("favorites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String   @default("")
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}
